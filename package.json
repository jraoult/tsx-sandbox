{
  "name": "tsx-sandbox",
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "yarn workspace @tsx-sandbox/main start",
    "test": "yarn workspace @tsx-sandbox/main build",
    "check:ts": "yarn workspaces foreach --all run check:ts",
    "check:format": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "3.8.3"
  }
}
